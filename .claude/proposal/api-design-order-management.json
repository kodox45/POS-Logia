    {
      "id": "EP-037",
      "method": "POST",
      "path": "/api/orders",
      "description": "Create a new order for a table with menu items. Triggers stock check and sends to kitchen display. Auto-calculates subtotal.",
      "source_features": ["F-001", "F-004"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [],
        "body": [
          { "name": "tableId", "type": "uuid", "required": true, "description": "Target table" },
          { "name": "items", "type": "array", "required": true, "description": "Array of order items", "items": { "menuItemId": "uuid", "quantity": "number", "specialNotes": "string|null" } },
          { "name": "specialNotes", "type": "string", "required": false, "description": "General order notes" },
          { "name": "discountId", "type": "uuid", "required": false, "description": "Applied discount ID" }
        ]
      },
      "response": {
        "success": {
          "status": 201,
          "body": {
            "id": "uuid",
            "orderNumber": "string",
            "tableId": "uuid",
            "orderStatus": "pending",
            "items": [{ "id": "uuid", "itemName": "string", "quantity": "number", "unitPrice": "decimal", "lineTotal": "decimal" }],
            "subtotalAmount": "decimal",
            "grandTotal": "decimal",
            "stockWarnings": [{ "menuItemId": "uuid", "menuItemName": "string", "ingredient": "string", "status": "low|critical" }],
            "createdAt": "ISO-8601"
          }
        },
        "errors": [
          { "status": 400, "code": "NO_ITEMS", "message": "Order must have at least one menu item" },
          { "status": 400, "code": "TABLE_NOT_FOUND", "message": "Table does not exist" },
          { "status": 400, "code": "ITEM_UNAVAILABLE", "message": "One or more menu items are unavailable" }
        ]
      },
      "business_rules": [
        {
          "rule": "Order must have at least one menu item",
          "type": "constraint",
          "source": "F-001.business_rules[0]"
        },
        {
          "rule": "Each order is linked to a specific table",
          "type": "constraint",
          "source": "F-001.business_rules[2]"
        },
        {
          "rule": "Stock deduction triggered on order submission",
          "steps": ["Check recipe ingredients for each order item", "Deduct from inventory", "Create stock movement records", "Update stock status if below threshold"],
          "triggers": ["order.created"],
          "side_effects": ["inventory.quantity reduced", "stock_movement records created", "low_stock_alert if below threshold"],
          "source": "F-004.business_rules[0]",
          "resolved_timing": {
            "trigger": "order.submitted (status = pending)",
            "rationale": "Deduct at submission for real-time accuracy. Reversed on cancellation/void via reversal StockMovement.",
            "alternatives_rejected": [{ "timing": "at payment completion", "reason": "Delays stock visibility, stock could appear available when already committed" }]
          }
        },
        {
          "rule": "Order total recalculated automatically",
          "formula": "SUM(item.unitPrice * item.quantity)",
          "inputs": ["OrderItem.unitPrice", "OrderItem.quantity"],
          "output": "Order.subtotalAmount",
          "source": "F-001.business_rules[6]"
        }
      ],
      "related_entity": "Order",
      "related_entity_id": "E-011",
      "domain_group": "order-management"
    },
    {
      "id": "EP-038",
      "method": "POST",
      "path": "/api/orders/:id/add-items",
      "description": "Add additional items to an existing active order. Items are labeled as 'Tambahan' and sent to kitchen separately.",
      "source_features": ["F-001"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [{ "name": "id", "type": "uuid", "required": true, "description": "Order ID" }],
        "body": [
          { "name": "items", "type": "array", "required": true, "description": "Additional items to add", "items": { "menuItemId": "uuid", "quantity": "number", "specialNotes": "string|null" } }
        ]
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "orderId": "uuid",
            "addedItems": [{ "id": "uuid", "itemName": "string", "quantity": "number", "unitPrice": "decimal", "lineTotal": "decimal", "isAdditional": true }],
            "newSubtotal": "decimal",
            "newGrandTotal": "decimal",
            "updatedAt": "ISO-8601"
          }
        },
        "errors": [
          { "status": 404, "code": "ORDER_NOT_FOUND", "message": "Order not found" },
          { "status": 400, "code": "ORDER_NOT_ACTIVE", "message": "Cannot add items to a paid/cancelled/voided order" }
        ]
      },
      "business_rules": [
        {
          "rule": "If a table already has an active (unpaid) order, cashier can ADD items to that existing order",
          "type": "constraint",
          "source": "F-001.business_rules[3]"
        },
        {
          "rule": "Additional items are appended to the same order with Tambahan label",
          "type": "constraint",
          "source": "F-001.business_rules[4]"
        },
        {
          "rule": "Additional items are sent to kitchen as new items with same order ID",
          "type": "constraint",
          "source": "F-001.business_rules[5]"
        }
      ],
      "related_entity": "Order",
      "related_entity_id": "E-011",
      "domain_group": "order-management"
    },
    {
      "id": "EP-039",
      "method": "PATCH",
      "path": "/api/orders/:id/status",
      "description": "Update order status. Handles state machine transitions: pending->cooking->ready->served->paid. Also handles cancellation.",
      "source_features": ["F-001", "F-002"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier", "chef"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [{ "name": "id", "type": "uuid", "required": true, "description": "Order ID" }],
        "body": [
          { "name": "status", "type": "enum", "required": true, "description": "New status", "values": ["cooking", "ready", "served", "cancelled"] }
        ]
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "id": "uuid",
            "orderStatus": "enum",
            "cookingStartedAt": "ISO-8601|null",
            "readyAt": "ISO-8601|null",
            "updatedAt": "ISO-8601"
          }
        },
        "errors": [
          { "status": 404, "code": "ORDER_NOT_FOUND", "message": "Order not found" },
          { "status": 400, "code": "INVALID_TRANSITION", "message": "Cannot transition from current status to requested status" },
          { "status": 403, "code": "ROLE_NOT_ALLOWED", "message": "Your role cannot perform this status transition" }
        ]
      },
      "business_rules": [
        {
          "rule": "Order can be cancelled before payment (status -> cancelled)",
          "type": "constraint",
          "source": "F-001.business_rules[7]"
        },
        {
          "rule": "When cancelling, reverse stock deductions via reversal StockMovement",
          "steps": ["Set order status to cancelled", "For each order item, look up recipe", "Create reversal stock movements (positive quantities)", "Update inventory quantities", "Release table if no other active orders"],
          "triggers": ["order.status -> cancelled"],
          "side_effects": ["inventory.quantity restored", "stock_movement reversal records created", "table.status may change to available"],
          "source": "F-001.business_rules[7]"
        }
      ],
      "related_entity": "Order",
      "related_entity_id": "E-011",
      "domain_group": "order-management"
    },
