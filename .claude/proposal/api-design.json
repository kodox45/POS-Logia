  "decisions_requiring_approval": [
    {
      "id": "D-030",
      "category": "api",
      "item": "Stock deduction timing for API: deduct at order submission or at payment completion?",
      "options": [
        "A: Deduct at order submission (status=pending) with reversal on cancel/void",
        "B: Deduct at payment completion only"
      ],
      "default": "A",
      "recommended": "A",
      "rationale": "F-004 states 'Stock deduction is triggered automatically when an order is confirmed'. Deducting at submission gives real-time stock accuracy and prevents overselling. Cancellation/void creates reversal StockMovement entries. This aligns with entity-level D-001 decision."
    },
    {
      "id": "D-031",
      "category": "api",
      "item": "Sync conflict resolution strategy: last-write-wins vs domain-specific merge rules?",
      "options": [
        "A: Last-write-wins for all entities (simpler)",
        "B: Last-write-wins for most entities, domain-specific merge for financial records (Transaction, Shift, VoidRecord)",
        "C: Full CRDT-based conflict resolution"
      ],
      "default": "B",
      "recommended": "B",
      "rationale": "Financial records (transactions, shifts, void records) are immutable once created and should never be overwritten. For these entities, server-side merge uses append-only semantics. Other entities (menu, inventory, settings) can use last-write-wins safely. Full CRDT (option C) is overengineered for 5 concurrent users."
    },
    {
      "id": "D-032",
      "category": "api",
      "item": "Receipt generation: server-side PDF or client-side HTML print?",
      "options": [
        "A: Client-side HTML/CSS print via browser Print API (offline-compatible)",
        "B: Server-side PDF generation endpoint"
      ],
      "default": "A",
      "recommended": "A",
      "rationale": "Offline-first architecture requires receipt printing without server. Client-side HTML print using react-to-print (already in tech-stack) formats receipt content as thermal-printer-compatible HTML. No server round-trip needed. Transaction detail endpoint (EP-053) provides all data needed for client-side rendering."
    },
    {
      "id": "D-033",
      "category": "api",
      "item": "Excel export: client-side generation or server-side?",
      "options": [
        "A: Client-side generation using SheetJS (xlsx package, already in tech-stack) -- works offline",
        "B: Server-side generation via dedicated export endpoint"
      ],
      "default": "A",
      "recommended": "A",
      "rationale": "SheetJS (xlsx) is already in the tech-stack for client-side Excel generation. EP-054 is designed as a data endpoint that returns structured data; the actual .xlsx file generation happens client-side using SheetJS. This works offline and avoids server dependency."
    }
  ],
