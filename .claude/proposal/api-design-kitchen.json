{
  "domain": "kitchen",
  "endpoints": [
    {
      "id": "EP-045",
      "method": "GET",
      "path": "/api/kitchen/orders",
      "description": "Get all orders for Kitchen Display queue. Shows pending and cooking orders with elapsed time. Orders exceeding target time are flagged.",
      "source_features": ["F-002"],
      "auth_required": true,
      "roles_allowed": ["owner", "chef"],
      "permission_required": null,
      "params": {
        "query": [
          { "name": "status", "type": "enum", "required": false, "description": "Filter by cooking status", "values": ["pending", "cooking", "ready"] }
        ],
        "path": [],
        "body": []
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "orders": [{
              "id": "uuid",
              "orderNumber": "string",
              "tableNumber": "number",
              "orderStatus": "enum",
              "specialNotes": "string|null",
              "items": [{ "id": "uuid", "itemName": "string", "quantity": "number", "specialNotes": "string|null", "cookingStatus": "enum", "isAdditional": "boolean", "recipeId": "uuid|null" }],
              "elapsedMinutes": "number",
              "isLate": "boolean",
              "cookingStartedAt": "ISO-8601|null",
              "createdAt": "ISO-8601"
            }],
            "pendingCount": "number",
            "cookingCount": "number",
            "readyCount": "number"
          }
        },
        "errors": []
      },
      "business_rules": [
        {
          "rule": "New orders appear at the top of the queue with audio/visual alert",
          "type": "constraint",
          "source": "F-002.business_rules[0]"
        },
        {
          "rule": "Orders exceeding target time (e.g., 15 min) are highlighted in red as late",
          "type": "constraint",
          "source": "F-002.business_rules[6]"
        },
        {
          "rule": "Additional items (tambahan) from same table appear as new items in the SAME order card",
          "type": "constraint",
          "source": "F-002.business_rules[7]"
        }
      ],
      "related_entity": "Order",
      "related_entity_id": "E-011",
      "domain_group": "kitchen"
    },
    {
      "id": "EP-046",
