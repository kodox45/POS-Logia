{
  "domain": "payment",
  "endpoints": [
    {
      "id": "EP-050",
      "method": "POST",
      "path": "/api/payments",
      "description": "Process payment for an order. Calculates PPN, validates amount, creates transaction record. Updates order status to paid and releases table.",
      "source_features": ["F-003", "F-016", "F-015"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [],
        "body": [
          { "name": "orderId", "type": "uuid", "required": true, "description": "Order to pay" },
          { "name": "paymentMethod", "type": "enum", "required": true, "description": "Payment method", "values": ["tunai", "qris", "gopay", "ovo", "dana", "shopeepay", "transfer_bank"] },
          { "name": "amountPaid", "type": "decimal", "required": true, "description": "Amount given by customer" },
          { "name": "digitalPaymentRef", "type": "string", "required": false, "description": "Reference number for digital payments" },
          { "name": "transferProofPhotoUrl", "type": "string", "required": false, "description": "Photo of transfer proof (for transfer_bank)" },
          { "name": "discountId", "type": "uuid", "required": false, "description": "Applied discount (if not already on order)" }
        ]
      },
      "response": {
        "success": {
          "status": 201,
          "body": {
            "transaction": {
              "id": "uuid",
              "transactionNumber": "string",
              "orderId": "uuid",
              "shiftId": "uuid",
              "tableNumber": "number",
              "subtotalAmount": "decimal",
              "discountName": "string|null",
              "discountAmount": "decimal",
              "ppnRate": "decimal",
              "ppnAmount": "decimal",
              "grandTotal": "decimal",
              "paymentMethod": "enum",
              "amountPaid": "decimal",
              "changeAmount": "decimal",
              "createdAt": "ISO-8601"
            },
            "orderStatus": "paid",
            "tableStatus": "available"
          }
        },
        "errors": [
          { "status": 400, "code": "INSUFFICIENT_AMOUNT", "message": "Payment cannot be processed if amount paid is less than grand total" },
          { "status": 400, "code": "NO_ACTIVE_SHIFT", "message": "Cashier must open a shift before processing any payment" },
          { "status": 404, "code": "ORDER_NOT_FOUND", "message": "Order not found" },
          { "status": 400, "code": "ORDER_NOT_PAYABLE", "message": "Order is not in a payable status (must be served or ready)" }
        ]
      },
      "business_rules": [
        {
          "rule": "PPN calculation",
          "formula": "(subtotal - discount) * (ppnRate / 100)",
          "inputs": ["subtotalAmount", "discountAmount", "ppnRate"],
          "output": "ppnAmount",
          "example": "100000 - 10000 = 90000; 90000 * 0.11 = 9900",
          "source": "F-003.business_rules[2]"
        },
        {
          "rule": "Grand total calculation",
          "formula": "(subtotal - discount) + ppnAmount",
          "inputs": ["subtotalAmount", "discountAmount", "ppnAmount"],
          "output": "grandTotal",
          "example": "90000 + 9900 = 99900",
          "source": "F-003.business_rules[2]"
        },
        {
          "rule": "Payment cannot be processed if amount paid is less than grand total",
          "type": "constraint",
          "source": "F-003.business_rules[3]"
        },
        {
          "rule": "CASH: Numpad input for amount received, auto-calculate change",
          "type": "constraint",
          "source": "F-003.business_rules[4]"
        },
        {
          "rule": "For digital payments: no change calculation needed (exact amount)",
          "type": "constraint",
          "source": "F-003.business_rules[8]"
        },
        {
          "rule": "Transaction stores SPECIFIC payment method name, NOT generic Digital",
          "type": "constraint",
          "source": "F-003.business_rules[9]"
        },
        {
          "rule": "Cashier MUST open a shift before processing any payment",
          "type": "constraint",
          "source": "F-015.business_rules[4]"
        },
        {
          "rule": "Discount applied BEFORE PPN calculation: Grand Total = (Subtotal - Discount) + PPN",
          "type": "constraint",
          "source": "F-018.business_rules[3]"
        },
        {
          "rule": "Only one discount per order (prevent stacking)",
          "type": "constraint",
          "source": "F-018.business_rules[4]"
        }
      ],
      "related_entity": "Transaction",
      "related_entity_id": "E-013",
      "domain_group": "payment"
    },
    {
      "id": "EP-051",
      "method": "POST",
      "path": "/api/orders/:id/void",
      "description": "Void a paid transaction. Requires PIN verification. Creates VoidRecord and adjusts shift expected cash.",
      "source_features": ["F-017"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [{ "name": "id", "type": "uuid", "required": true, "description": "Order ID to void" }],
        "body": [
          { "name": "voidType", "type": "enum", "required": true, "description": "Type of void", "values": ["full_void", "partial_void"] },
          { "name": "voidReason", "type": "enum", "required": true, "description": "Mandatory reason", "values": ["salah_input", "customer_batal", "item_habis", "lainnya"] },
          { "name": "voidNotes", "type": "string", "required": false, "description": "Additional explanation" },
          { "name": "voidedItems", "type": "array", "required": false, "description": "Items to void (for partial_void only)", "items": { "orderItemId": "uuid", "quantity": "number" } },
          { "name": "pinVerified", "type": "boolean", "required": true, "description": "Must be true (PIN verified via /api/auth/verify-pin first)" }
        ]
      },
      "response": {
        "success": {
          "status": 201,
          "body": {
            "voidRecord": {
              "id": "uuid",
              "voidNumber": "string",
              "voidType": "enum",
              "voidReason": "enum",
              "voidAmount": "decimal",
              "createdAt": "ISO-8601"
            },
            "orderStatus": "voided",
            "shiftExpectedCashAdjustment": "decimal"
          }
        },
        "errors": [
          { "status": 404, "code": "ORDER_NOT_FOUND", "message": "Order not found" },
          { "status": 400, "code": "ORDER_NOT_PAID", "message": "Can only void a paid order" },
          { "status": 400, "code": "PIN_NOT_VERIFIED", "message": "PIN verification required before void" },
          { "status": 400, "code": "REASON_REQUIRED", "message": "Void reason is mandatory" }
        ]
      },
      "business_rules": [
        {
          "rule": "PIN verification required before any void operation",
          "type": "constraint",
          "source": "F-017.business_rules[0]"
        },
        {
          "rule": "Void after payment (full): full refund tracked, expected cash reduced in shift",
          "type": "constraint",
          "source": "F-017.business_rules[2]"
        },
        {
          "rule": "Void reason is MANDATORY - kasir must select reason",
          "type": "constraint",
          "source": "F-017.business_rules[4]"
        },
        {
          "rule": "All voids are logged immutably for audit trail",
          "type": "constraint",
          "source": "F-017.business_rules[5]"
        },
        {
          "rule": "Expected cash formula updated on void",
          "formula": "opening_balance + cash_sales - cash_refunds_from_voids",
          "inputs": ["Shift.openingBalance", "Shift.cashSalesTotal", "VoidRecord.voidAmount"],
          "output": "Shift.expectedCash",
          "source": "F-017.business_rules[6]"
        }
      ],
      "related_entity": "VoidRecord",
      "related_entity_id": "E-015",
      "domain_group": "payment"
    },
    {
      "id": "EP-052",
