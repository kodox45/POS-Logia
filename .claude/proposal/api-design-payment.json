          { "name": "dateFrom", "type": "date", "required": false, "description": "Start date" },
          { "name": "dateTo", "type": "date", "required": false, "description": "End date" },
          { "name": "transactionNumber", "type": "string", "required": false, "description": "Search by transaction ID" },
          { "name": "cashierId", "type": "uuid", "required": false, "description": "Filter by PIC cashier" },
          { "name": "shiftId", "type": "uuid", "required": false, "description": "Filter by shift" },
          { "name": "paymentMethod", "type": "enum", "required": false, "description": "Filter by payment method" },
          { "name": "totalMin", "type": "decimal", "required": false, "description": "Minimum grand total" },
          { "name": "totalMax", "type": "decimal", "required": false, "description": "Maximum grand total" },
          { "name": "transactionStatus", "type": "enum", "required": false, "description": "Filter by status", "values": ["completed", "voided"] }
        ],
        "path": [],
        "body": []
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "transactions": [{ "id": "uuid", "transactionNumber": "string", "orderId": "uuid", "tableNumber": "number", "shiftId": "uuid", "shiftNumber": "string", "cashierId": "uuid", "cashierName": "string", "subtotalAmount": "decimal", "discountAmount": "decimal", "ppnRate": "decimal", "ppnAmount": "decimal", "grandTotal": "decimal", "paymentMethod": "enum", "transactionStatus": "enum", "createdAt": "ISO-8601" }],
            "total": "number",
            "summaryStats": {
              "count": "number",
              "totalRevenue": "decimal",
              "cashTotal": "decimal",
              "digitalTotal": "decimal"
            }
          }
        },
        "errors": []
      },
      "business_rules": [
        {
          "rule": "Transaction data cannot be deleted by non-owner users",
          "type": "constraint",
          "source": "F-011"
        }
      ],
      "related_entity": "Transaction",
      "related_entity_id": "E-013",
      "domain_group": "payment"
    },
