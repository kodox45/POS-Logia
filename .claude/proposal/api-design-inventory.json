      "auth_required": true,
      "roles_allowed": ["owner"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [{ "name": "id", "type": "uuid", "required": true, "description": "Inventory item ID" }],
        "body": [
          { "name": "quantity", "type": "decimal", "required": true, "description": "Quantity to add" },
          { "name": "reason", "type": "string", "required": false, "description": "Reason for restock" }
