        "path": [],
        "body": []
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "inventoryItems": [{ "id": "uuid", "itemName": "string", "quantity": "decimal", "unit": "string", "minimumThreshold": "decimal|null", "stockStatus": "enum" }],
