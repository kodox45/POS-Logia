      "roles_allowed": ["owner"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [{ "name": "id", "type": "uuid", "required": true, "description": "Inventory item ID" }],
        "body": []
      },
      "response": {
        "success": { "status": 200, "body": { "message": "Inventory item deleted successfully" } },
        "errors": [
          { "status": 404, "code": "INVENTORY_ITEM_NOT_FOUND", "message": "Inventory item not found" },
          { "status": 409, "code": "ITEM_IN_USE", "message": "Cannot delete inventory item referenced by recipes" }
        ]
