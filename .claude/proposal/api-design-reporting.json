{
  "domain": "reporting",
  "endpoints": [
    {
      "id": "EP-062",
      "method": "GET",
      "path": "/api/reports/dashboard",
      "description": "Get daily sales dashboard data. Shows total revenue, order count, top-selling items, and payment method breakdown. Used by Admin Dashboard (S-008).",
      "source_features": ["F-007", "F-012"],
      "auth_required": true,
      "roles_allowed": ["owner"],
      "permission_required": "perm-view-reports",
      "params": {
        "query": [
          { "name": "dateFrom", "type": "date", "required": false, "description": "Start date (defaults to today)" },
          { "name": "dateTo", "type": "date", "required": false, "description": "End date (defaults to today)" }
        ],
        "path": [],
        "body": []
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "period": { "from": "date", "to": "date" },
            "totalRevenue": "decimal",
            "totalOrders": "number",
            "averageOrderValue": "decimal",
            "topSellingItems": [{ "menuItemId": "uuid", "itemName": "string", "quantitySold": "number", "revenue": "decimal" }],
            "paymentMethodBreakdown": [{ "method": "enum", "count": "number", "total": "decimal", "percentage": "decimal" }],
            "revenueByHour": [{ "hour": "number", "revenue": "decimal", "orderCount": "number" }],
            "lowStockAlertCount": "number"
          }
        },
        "errors": []
      },
      "business_rules": [
        {
          "rule": "Report data updates in real-time as transactions are completed",
          "type": "constraint",
          "source": "F-007.business_rules[0]"
        },
        {
          "rule": "Only completed (paid) orders are counted in revenue",
          "type": "constraint",
          "source": "F-007.business_rules[1]"
        }
      ],
      "related_entity": "Transaction",
      "related_entity_id": "E-013",
      "domain_group": "reporting"
    },
    {
      "id": "EP-063",
