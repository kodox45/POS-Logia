          { "name": "username", "type": "string", "required": true, "description": "Unique username for login" },
          { "name": "password", "type": "string", "required": true, "description": "Password (will be hashed with bcrypt)" },
          { "name": "displayName", "type": "string", "required": true, "description": "Name shown in the system" },
          { "name": "role", "type": "enum", "required": true, "description": "User role", "values": ["waiter-cashier", "chef"] },
          { "name": "pin", "type": "string", "required": false, "description": "4-6 digit PIN (will be hashed)" }
        ]
      },
      "response": {
        "success": {
          "status": 201,
          "body": {
