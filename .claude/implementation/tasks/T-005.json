  "business_rules": [
    {
      "rule": "Cashier MUST verify PIN before opening a shift",
      "type": "constraint",
      "source": "F-015"
    },
    {
      "rule": "Only one active shift per cashier at a time",
      "type": "constraint",
      "source": "F-015"
    },
    {
      "rule": "Expected cash = opening_balance + cash_sales - cash_refunds_from_voids",
      "type": "calculation",
      "formula": "openingBalance + cashSalesTotal - voidTotalAmount",
      "source": "F-015"
    },
    {
      "rule": "Closing is a ONE-WAY session",
      "type": "constraint",
      "source": "F-015"
    },
    {
      "rule": "If discrepancy exists, notes are MANDATORY",
      "type": "constraint",
      "source": "F-015"
    },
    {
      "rule": "Closed shift data is immutable and logged for audit",
      "type": "constraint",
      "source": "F-015"
    }
  ],
  "state_dependencies": {
    "owns_store": "useShiftManagementStore",
    "writes_to_tables": [
      "shifts"
    ],
    "reads_from_tables": [
      "users",
      "transactions",
      "voidRecords"
    ],
    "calls_other_stores": [
