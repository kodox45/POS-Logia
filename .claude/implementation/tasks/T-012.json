  "business_rules": [
    {
      "rule": "Unavailable items are hidden from the order screen",
      "type": "constraint",
      "source": "F-005"
    },
    {
      "rule": "Price changes take effect immediately for new orders",
      "type": "constraint",
      "source": "F-005"
    },
    {
      "rule": "Recipe ingredients must reference inventory items for stock deduction",
      "type": "constraint",
      "source": "F-006"
    },
    {
      "rule": "Only Owner or authorized chef can edit recipes",
      "type": "constraint",
      "source": "F-006"
    },
    {
      "rule": "PPN is calculated as: ppn_amount = subtotal * (ppn_rate / 100)",
      "type": "calculation",
      "formula": "subtotal * (ppn_rate / 100)",
      "source": "F-016"
    },
    {
      "rule": "Changes to PPN rate apply to new transactions only, not retroactively",
      "type": "constraint",
      "source": "F-016"
    },
    {
      "rule": "Discount applied BEFORE PPN calculation: Grand Total = (Subtotal - Discount) + PPN",
      "type": "calculation",
      "formula": "(Subtotal - Discount) + ppnAmount",
      "source": "F-018"
    },
    {
      "rule": "Only one discount per order (prevent stacking)",
      "type": "constraint",
      "source": "F-018"
    }
  ],
  "state_dependencies": null,
  "db_scope": {
