{
  "domain": "settings",
  "version": "1.0",
  "wave": 1,
  "depends_on_domains": [],

  "entities": {
    "owns": [
      {
        "name": "PosSettings",
        "id": "E-018",
        "table_name": "posSettings",
        "attributes": [
          { "name": "id", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "ppnEnabled", "type": "boolean", "category": "business", "required": true, "unique": false, "default": true, "source": "F-016.fields[0]" },
          { "name": "ppnRate", "type": "decimal", "category": "business", "required": true, "unique": false, "default": 11, "source": "F-016.fields[1]" },
          { "name": "restaurantName", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 255, "source": "F-016.fields[2]" },
          { "name": "restaurantAddress", "type": "text", "category": "business", "required": false, "unique": false, "default": null, "source": "F-016.fields[3]" },
          { "name": "receiptFooter", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 500, "source": "F-016.fields[4]" },
          { "name": "showPpnOnReceipt", "type": "boolean", "category": "business", "required": true, "unique": false, "default": true, "source": "inferred:prototype-summary" },
          { "name": "qrisImageUrl", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 500, "source": "F-003.business_rules[5]" },
          { "name": "bankName", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 255, "source": "inferred:prototype-summary" },
          { "name": "bankAccountNumber", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 50, "source": "inferred:prototype-summary" },
          { "name": "bankAccountHolder", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 255, "source": "inferred:prototype-summary" },
          { "name": "restaurantLogoUrl", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 500, "source": "inferred:structural" },
          { "name": "syncId", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "lastSynced", "type": "timestamp", "category": "system", "required": false, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "syncStatus", "type": "enum", "category": "system", "required": true, "unique": false, "default": "pending", "values": ["synced", "pending", "conflict"], "source": "inferred:technical" },
          { "name": "createdAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "updatedAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" }
        ],
        "relationships": [
          { "target": "EwalletProvider", "type": "one-to-many", "foreign_key": "posSettingsId", "cascade_delete": true }
        ],
        "indexes": [],
        "state_machine": null,
        "business_rules": [
          { "rule": "PPN rate is configurable by owner in system settings", "type": "constraint", "source": "F-016.business_rules[0]", "enforcement": "update" },
          { "rule": "PPN applies to all transactions when enabled", "type": "constraint", "source": "F-016.business_rules[3]", "enforcement": "both" },
          { "rule": "Changes to PPN rate apply to new transactions only, not retroactively", "type": "constraint", "source": "F-016.business_rules[5]", "enforcement": "update" }
        ]
      },
      {
        "name": "EwalletProvider",
        "id": "E-019",
        "table_name": "ewalletProviders",
