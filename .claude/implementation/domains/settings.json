          { "name": "ppnRate", "type": "decimal", "required": false, "description": "PPN percentage (e.g., 11 for 11%)" },
          { "name": "restaurantName", "type": "string", "required": false, "description": "Name on receipts" },
          { "name": "restaurantAddress", "type": "string", "required": false, "description": "Address on receipts" },
          { "name": "receiptFooter", "type": "string", "required": false, "description": "Custom footer text" },
