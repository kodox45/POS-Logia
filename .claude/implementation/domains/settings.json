          { "name": "bankName", "type": "string", "required": false, "description": "Bank name for transfers" },
          { "name": "bankAccountNumber", "type": "string", "required": false, "description": "Bank account number" },
          { "name": "bankAccountHolder", "type": "string", "required": false, "description": "Account holder name" },
          { "name": "restaurantLogoUrl", "type": "string", "required": false, "description": "Logo URL for receipts" }
        ]
      },
      "response": {
