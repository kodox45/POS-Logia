  "screens": [
    {
      "screen_id": "S-017",
      "name": "POS System Settings (Pengaturan POS)",
      "page_component": "SystemSettingsPage",
      "route": "/admin/settings",
      "interface": "admin-panel",
      "layout": "AdminLayout",
      "guards": ["AuthGuard", "RoleGuard"],
      "sections": [
        {
          "name": "Tax / PPN Settings",
          "position": "section",
          "description": "Toggle PPN on/off. Input PPN rate percentage (default 11%). Preview calculation example.",
          "components": ["toggle-switch", "number-input", "preview-calc"]
        },
        {
          "name": "Payment Method Settings",
          "position": "section",
          "description": "Configure available payment methods. QRIS: upload static QR code image shown during QRIS payment. Bank Transfer: input bank name, account number, account holder name. E-Wallet: toggle available providers (GoPay, OVO, Dana, ShopeePay) AND upload QR code image PER PROVIDER. Enable/disable each payment method globally.",
          "components": ["image-upload", "text-input", "toggle-switch", "per-provider-qr-upload"]
        },
        {
          "name": "Discount / Promo Management",
          "position": "section",
          "description": "Create, edit, activate/deactivate discount rules. Table showing all discounts: name, type (percentage/fixed), value, status (active/inactive). Add button to create new. Each row has edit and toggle active. Only one discount applicable per order.",
          "components": ["data-table", "add-button", "toggle-switch", "form-modal"]
        },
        {
          "name": "Restaurant Info",
          "position": "section",
          "description": "Restaurant name, address -- shown on printed receipts. Optional logo upload for receipt header.",
          "components": ["text-input", "image-upload"]
        },
        {
          "name": "Receipt Settings",
          "position": "section",
          "description": "Custom footer text for receipts. Toggle to show/hide PPN breakdown on receipt.",
          "components": ["text-input", "toggle-switch"]
        },
        {
          "name": "Save Action",
          "position": "bottom",
          "description": "Save settings button. Changes apply to new transactions immediately.",
          "components": ["save-button"]
        }
      ]
    }
  ],

  "features": [
    {
      "id": "F-016",
      "title": "POS System Settings (Tax/PPN Configuration)",
      "priority": "must_have",
      "acceptance_criteria": [
        "Owner can access POS Settings from admin panel or Dashboard Hub",
        "Owner can toggle PPN on/off",
        "Owner can set PPN rate percentage",
        "Payment screen shows subtotal, PPN amount, and grand total",
        "Printed receipt includes PPN breakdown",
        "Transaction history shows PPN info per transaction"
      ],
      "business_rules": [
        { "rule": "PPN rate is configurable by owner in system settings", "type": "constraint", "source": "F-016.business_rules[0]", "enforcement": "update" },
        { "rule": "PPN is calculated as: ppn_amount = subtotal * (ppn_rate / 100)", "type": "formula", "source": "F-016.business_rules[1]", "enforcement": "both" },
        { "rule": "Grand total = subtotal + ppn_amount", "type": "formula", "source": "F-016.business_rules[2]", "enforcement": "both" },
        { "rule": "PPN applies to all transactions when enabled", "type": "constraint", "source": "F-016.business_rules[3]", "enforcement": "both" },
        { "rule": "PPN breakdown must be visible on payment screen and on printed receipt", "type": "constraint", "source": "F-016.business_rules[4]", "enforcement": "both" },
        { "rule": "Changes to PPN rate apply to new transactions only, not retroactively", "type": "constraint", "source": "F-016.business_rules[5]", "enforcement": "update" }
      ]
    },
    {
      "id": "F-018",
      "title": "Discount / Promo Management",
      "priority": "should_have",
      "acceptance_criteria": [
        "Owner can create/edit/deactivate discount rules in settings",
        "Active promos shown as banner cards on order creation screen (S-003)",
        "Cashier can tap promo banner to apply discount during order creation",
        "Applied promo carries through to payment screen automatically",
        "Cashier can also add/change discount from payment screen",
        "Discount picker shows all active discounts with calculated amount",
        "Payment shows: Subtotal -> Diskon -> Subtotal setelah diskon -> PPN -> Grand Total",
        "Receipt includes discount line",
        "Transaction history shows discount info"
      ],
      "business_rules": [
        { "rule": "Owner creates and manages discount/promo options in settings", "type": "constraint", "source": "F-018.business_rules[0]", "enforcement": "both" },
