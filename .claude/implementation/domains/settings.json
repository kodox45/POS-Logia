          { "name": "appliedTo", "type": "enum", "category": "business", "required": true, "unique": false, "default": "whole_order", "values": ["whole_order", "specific_items"], "source": "F-018.fields[3]" },
          { "name": "isActive", "type": "boolean", "category": "business", "required": true, "unique": false, "default": true, "source": "F-018.fields[4]" },
          { "name": "syncId", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "lastSynced", "type": "timestamp", "category": "system", "required": false, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "syncStatus", "type": "enum", "category": "system", "required": true, "unique": false, "default": "pending", "values": ["synced", "pending", "conflict"], "source": "inferred:technical" },
          { "name": "createdAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "updatedAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" }
        ],
        "relationships": [
          { "target": "Order", "type": "one-to-many", "foreign_key": "discountId", "cascade_delete": false }
        ],
        "indexes": [
          { "fields": ["isActive"], "unique": false }
        ],
        "state_machine": null,
        "business_rules": [
          { "rule": "Owner creates and manages discount/promo options in settings", "type": "constraint", "source": "F-018.business_rules[0]", "enforcement": "both" },
          { "rule": "Discount applied BEFORE PPN calculation: Grand Total = (Subtotal - Discount) + PPN", "type": "formula", "source": "F-018.business_rules[3]", "enforcement": "both" },
          { "rule": "Only one discount per order (prevent stacking)", "type": "constraint", "source": "F-018.business_rules[4]", "enforcement": "both" },
          { "rule": "Owner can activate/deactivate discounts anytime", "type": "constraint", "source": "F-018.business_rules[7]", "enforcement": "update" }
        ]
      }
    ],
    "reads": [
      {
        "name": "Order",
        "id": "E-010",
        "read_fields": ["id", "discountId"]
      }
    ]
