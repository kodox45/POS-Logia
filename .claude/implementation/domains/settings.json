          { "name": "posSettingsId", "type": "uuid", "category": "reference", "required": true, "unique": false, "default": null, "source": "inferred:structural" },
          { "name": "providerName", "type": "string", "category": "business", "required": true, "unique": true, "default": null, "max_length": 100, "source": "inferred:prototype-summary" },
          { "name": "isEnabled", "type": "boolean", "category": "business", "required": true, "unique": false, "default": false, "source": "inferred:prototype-summary" },
          { "name": "qrImageUrl", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 500, "source": "inferred:prototype-summary" },
          { "name": "syncId", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "lastSynced", "type": "timestamp", "category": "system", "required": false, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "syncStatus", "type": "enum", "category": "system", "required": true, "unique": false, "default": "pending", "values": ["synced", "pending", "conflict"], "source": "inferred:technical" },
          { "name": "createdAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "updatedAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" }
        ],
        "relationships": [
          { "target": "PosSettings", "type": "many-to-one", "foreign_key": "posSettingsId", "cascade_delete": true }
        ],
        "indexes": [
          { "fields": ["providerName"], "unique": true },
          { "fields": ["isEnabled"], "unique": false }
        ],
        "state_machine": null,
        "business_rules": [
          { "rule": "E-Wallet provider shows specific QR code for that provider during payment", "type": "constraint", "source": "F-003.business_rules[6]", "enforcement": "both" }
        ]
      },
      {
        "name": "Discount",
        "id": "E-016",
        "table_name": "discounts",
        "attributes": [
          { "name": "id", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
