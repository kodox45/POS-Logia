  "features": [
    {
      "id": "F-003",
      "title": "Cashier & Payment Processing",
      "priority": "must_have",
      "acceptance_criteria": [
        "Payment screen shows subtotal, PPN %, PPN amount, and grand total",
        "Cashier can select payment method and input amount received",
        "Change is calculated against grand total (inclusive PPN)",
        "After payment: success popup with checkmark, summary, and Print Struk button",
        "Cashier can print receipt from success popup",
        "Cashier can tap Selesai to return to order list",
        "Past transactions can be viewed in detail and receipt reprinted from S-012",
        "Completed payment updates order status to paid"
      ],
      "business_rules": [
        { "rule": "Bill shows subtotal, discount (if any), PPN amount, and grand total separately", "type": "constraint", "source": "F-003.business_rules[0]", "enforcement": "both" },
        { "rule": "PPN rate is pulled from system settings (F-016)", "type": "constraint", "source": "F-003.business_rules[1]", "enforcement": "both" },
        { "rule": "Discount applied before PPN: (Subtotal - Discount) x PPN rate", "type": "formula", "source": "F-003.business_rules[2]", "enforcement": "both" },
        { "rule": "Payment cannot be processed if amount paid is less than grand total", "type": "constraint", "source": "F-003.business_rules[3]", "enforcement": "both" },
        { "rule": "Transaction stores SPECIFIC payment method name, NOT generic Digital", "type": "constraint", "source": "F-003.business_rules[9]", "enforcement": "both" }
      ]
    },
    {
      "id": "F-011",
      "title": "Transaction History",
      "priority": "should_have",
      "acceptance_criteria": [
        "Transaction table shows: date/time, ID, table, Shift ID, PIC Kasir, subtotal, PPN, total, payment method",
        "Transactions can be filtered by: date range, transaction ID, PIC Kasir, Shift ID, payment method, total range",
        "All filters are combinable and have a reset button",
        "Summary stats (count, total revenue, cash total, digital total) update with active filters",
        "Each transaction shows full detail modal with PPN breakdown and Print Struk button",
        "Filtered data can be exported to Excel (.xlsx)",
        "Transaction data cannot be deleted by non-owner users"
      ],
      "business_rules": []
    },
    {
      "id": "F-013",
      "title": "Report Export to Excel",
      "priority": "should_have",
      "acceptance_criteria": [
        "Export button on Transaction History (S-012) generates Excel file",
        "Export includes all visible columns: date, ID, table, shift, PIC, subtotal, PPN, total, method",
        "Export respects currently active filters (only exports filtered results)",
        "Excel file includes header row and formatted data",
        "Loading indicator shown during export generation"
      ],
      "business_rules": []
    },
    {
      "id": "F-017",
      "title": "Void / Cancel Order & Transaction",
      "priority": "must_have",
      "acceptance_criteria": [
        "Cashier can cancel an unpaid order from order list",
        "Cashier can void a paid transaction (requires PIN)",
        "Void reason selection is mandatory",
        "Voided amounts are reflected in shift expected cash calculation",
        "Close shift summary shows void count and total void amount",
        "Owner can see void history in transaction report"
      ],
      "business_rules": [
        { "rule": "PIN verification required before any void operation", "type": "constraint", "source": "F-017.business_rules[0]", "enforcement": "both" },
        { "rule": "All voids are logged immutably for audit trail", "type": "constraint", "source": "F-017.business_rules[5]", "enforcement": "both" }
      ]
    }
  ],

