{
  "domain": "auth",
  "version": "1.0",
  "wave": 1,
  "depends_on_domains": [],

  "entities": {
    "owns": [
      {
        "name": "User",
        "id": "E-001",
        "table_name": "users",
        "attributes": [
          { "name": "id", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "username", "type": "string", "category": "business", "required": true, "unique": true, "default": null, "max_length": 255, "source": "F-009.fields[0]" },
          { "name": "passwordHash", "type": "string", "category": "business", "required": true, "unique": false, "default": null, "max_length": 255, "source": "F-009.fields[1]" },
          { "name": "pinHash", "type": "string", "category": "business", "required": false, "unique": false, "default": null, "max_length": 255, "source": "F-015.business_rules[0]" },
          { "name": "role", "type": "enum", "category": "business", "required": true, "unique": false, "default": null, "values": ["owner", "waiter-cashier", "chef"], "source": "F-009.fields[2]" },
          { "name": "displayName", "type": "string", "category": "business", "required": true, "unique": false, "default": null, "max_length": 255, "source": "F-009.fields[3]" },
          { "name": "isActive", "type": "boolean", "category": "business", "required": true, "unique": false, "default": true, "source": "F-009.business_rules[3]" },
          { "name": "lastLoginAt", "type": "timestamp", "category": "system", "required": false, "unique": false, "default": null, "source": "inferred:prototype-summary" },
          { "name": "syncId", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "lastSynced", "type": "timestamp", "category": "system", "required": false, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "syncStatus", "type": "enum", "category": "system", "required": true, "unique": false, "default": "pending", "values": ["synced", "pending", "conflict"], "source": "inferred:technical" },
          { "name": "createdAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "updatedAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" }
        ],
        "relationships": [
          { "target": "UserPermission", "type": "one-to-many", "foreign_key": "userId", "cascade_delete": true },
          { "target": "Shift", "type": "one-to-many", "foreign_key": "picCashierId", "cascade_delete": false },
          { "target": "Order", "type": "one-to-many", "foreign_key": "waiterId", "cascade_delete": false }
        ],
        "indexes": [
          { "fields": ["username"], "unique": true },
          { "fields": ["role"], "unique": false },
          { "fields": ["isActive"], "unique": false }
        ],
        "state_machine": null,
        "business_rules": [
          { "rule": "Each user must have a unique username", "type": "constraint", "source": "F-009.business_rules[0]", "enforcement": "create" },
          { "rule": "After login, ALL users are routed to the Main Dashboard Hub", "type": "constraint", "source": "F-009.business_rules[1]", "enforcement": "both" },
          { "rule": "Owner can create, edit, and deactivate user accounts", "type": "constraint", "source": "F-009.business_rules[3]", "enforcement": "both" },
          { "rule": "Failed login attempts are logged", "type": "constraint", "source": "F-009.business_rules[4]", "enforcement": "both" },
          { "rule": "Owner can set and reset PIN per user for shift operations", "type": "constraint", "source": "F-009.business_rules[5]", "enforcement": "update" }
        ]
      },
      {
        "name": "UserPermission",
        "id": "E-002",
        "table_name": "userPermissions",
        "attributes": [
          { "name": "id", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "userId", "type": "uuid", "category": "reference", "required": true, "unique": false, "default": null, "source": "F-008.fields[0]" },
          { "name": "permissionKey", "type": "string", "category": "business", "required": true, "unique": false, "default": null, "max_length": 255, "source": "F-008.fields[1]" },
          { "name": "isGranted", "type": "boolean", "category": "business", "required": true, "unique": false, "default": false, "source": "F-008.fields[1]" },
          { "name": "syncId", "type": "uuid", "category": "system", "required": true, "unique": true, "default": null, "source": "inferred:technical" },
          { "name": "lastSynced", "type": "timestamp", "category": "system", "required": false, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "syncStatus", "type": "enum", "category": "system", "required": true, "unique": false, "default": "pending", "values": ["synced", "pending", "conflict"], "source": "inferred:technical" },
          { "name": "createdAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" },
          { "name": "updatedAt", "type": "timestamp", "category": "system", "required": true, "unique": false, "default": null, "source": "inferred:technical" }
        ],
        "relationships": [
          { "target": "User", "type": "many-to-one", "foreign_key": "userId", "cascade_delete": true }
        ],
        "indexes": [
          { "fields": ["userId", "permissionKey"], "unique": true },
          { "fields": ["userId"], "unique": false }
        ],
        "state_machine": null,
        "business_rules": [
          { "rule": "Only Owner can access the access control panel", "type": "constraint", "source": "F-008.business_rules[0]", "enforcement": "both" },
          { "rule": "Permission changes take effect immediately", "type": "constraint", "source": "F-008.business_rules[1]", "enforcement": "update" },
          { "rule": "Each role has default permissions that can be overridden per individual user", "type": "constraint", "source": "F-008.business_rules[2]", "enforcement": "create" },
          { "rule": "Core permissions cannot be removed", "type": "constraint", "source": "F-008.business_rules[3]", "enforcement": "update" }
        ]
      }
    ],
    "reads": [
      {
        "name": "Shift",
        "id": "E-015",
        "read_fields": ["id", "picCashierId", "status", "shiftNumber", "startTime"]
      }
    ]
  },

  "endpoints": [
    {
      "id": "EP-001",
      "method": "POST",
      "path": "/api/auth/login",
      "description": "Authenticate user with username and password. Validates credentials against local bcrypt hash in IndexedDB. Returns session token stored locally.",
      "source_features": ["F-009"],
      "auth_required": false,
      "roles_allowed": ["owner", "waiter-cashier", "chef"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [],
        "body": [
          { "name": "username", "type": "string", "required": true, "description": "Unique username" },
          { "name": "password", "type": "string", "required": true, "description": "Plain-text password for bcrypt comparison" }
        ]
      },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "user": { "id": "uuid", "username": "string", "role": "enum", "displayName": "string", "isActive": "boolean" },
            "sessionToken": "string",
            "permissions": ["string"]
          }
        },
        "errors": [
          { "status": 401, "code": "INVALID_CREDENTIALS", "message": "Username or password is incorrect" },
          { "status": 403, "code": "ACCOUNT_DEACTIVATED", "message": "User account has been deactivated" }
        ]
      },
      "business_rules": [
        { "rule": "Each user must have a unique username", "type": "constraint", "field": "username", "validation": "unique", "source": "F-009.business_rules[0]" },
        { "rule": "After login, ALL users are routed to the Main Dashboard Hub", "type": "constraint", "source": "F-009.business_rules[1]" },
        { "rule": "Failed login attempts are logged", "type": "constraint", "source": "F-009.business_rules[4]" }
      ],
      "related_entity": "User",
      "related_entity_id": "E-001",
      "domain_group": "auth"
    },
    {
      "id": "EP-002",
      "method": "POST",
      "path": "/api/auth/logout",
      "description": "End the current user session. Clears session token from IndexedDB.",
      "source_features": ["F-009"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier", "chef"],
      "permission_required": null,
      "params": { "query": [], "path": [], "body": [] },
      "response": {
        "success": { "status": 200, "body": { "message": "Logged out successfully" } },
        "errors": [
          { "status": 401, "code": "NOT_AUTHENTICATED", "message": "No active session" }
        ]
      },
      "business_rules": [],
      "related_entity": "User",
      "related_entity_id": "E-001",
      "domain_group": "auth"
    },
    {
      "id": "EP-003",
      "method": "POST",
      "path": "/api/auth/verify-pin",
      "description": "Verify a user's PIN for shift operations, POS entry gate, or void operations. Compares input against local bcrypt pinHash.",
      "source_features": ["F-015", "F-017"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier"],
      "permission_required": null,
      "params": {
        "query": [],
        "path": [],
        "body": [
          { "name": "userId", "type": "uuid", "required": true, "description": "ID of the user whose PIN is being verified" },
          { "name": "pin", "type": "string", "required": true, "description": "4-6 digit PIN for verification" },
          { "name": "context", "type": "enum", "required": true, "description": "Context of PIN verification", "values": ["shift_open", "pos_entry", "void_operation"] }
        ]
      },
      "response": {
        "success": { "status": 200, "body": { "verified": true, "verifiedAt": "ISO-8601" } },
        "errors": [
          { "status": 401, "code": "INVALID_PIN", "message": "PIN is incorrect" },
          { "status": 404, "code": "PIN_NOT_SET", "message": "User does not have a PIN configured" }
        ]
      },
      "business_rules": [
        { "rule": "Cashier MUST verify PIN before opening a shift", "type": "constraint", "source": "F-015.business_rules[0]" },
        { "rule": "Cashier MUST re-verify PIN every time they enter POS operational screens from outside POS", "type": "constraint", "source": "F-015.business_rules[1]" },
        { "rule": "PIN verification required before any void operation", "type": "constraint", "source": "F-017.business_rules[0]" }
      ],
      "related_entity": "User",
      "related_entity_id": "E-001",
      "domain_group": "auth"
    },
    {
      "id": "EP-004",
      "method": "GET",
      "path": "/api/auth/session",
      "description": "Get the current authenticated user session including role, permissions, and active shift status.",
      "source_features": ["F-009", "F-008"],
      "auth_required": true,
      "roles_allowed": ["owner", "waiter-cashier", "chef"],
      "permission_required": null,
      "params": { "query": [], "path": [], "body": [] },
      "response": {
        "success": {
          "status": 200,
          "body": {
            "user": { "id": "uuid", "username": "string", "role": "enum", "displayName": "string" },
            "permissions": ["string"],
            "activeShift": { "id": "uuid", "shiftNumber": "string", "startTime": "ISO-8601" }
          }
        },
        "errors": [
          { "status": 401, "code": "NOT_AUTHENTICATED", "message": "No active session" }
        ]
      },
      "business_rules": [],
      "related_entity": "User",
      "related_entity_id": "E-001",
      "domain_group": "auth"
    }
  ],

  "screens": [
    {
      "screen_id": "S-001",
      "name": "Login Screen",
      "page_component": "LoginPage",
      "route": "/login",
      "interface": "shared",
      "layout": "none",
      "guards": [],
      "sections": [
        {
          "name": "Brand Header",
          "position": "top",
          "description": "LogiaInitiative logo and app name (POS Restoran UMKM Logia)",
          "components": ["logo-display", "app-title"]
        },
        {
          "name": "Login Form",
          "position": "center",
          "description": "Username and password fields with login button",
          "components": ["text-input", "password-input", "login-button"]
        },
        {
          "name": "Error Message",
          "position": "center-bottom",
          "description": "Displays login error messages (wrong credentials, account deactivated)",
          "components": ["alert-message"]
        }
      ]
    },
    {
      "screen_id": "S-016",
      "name": "Main Dashboard Hub",
      "page_component": "DashboardHubPage",
      "route": "/dashboard",
      "interface": "shared",
      "layout": "DashboardHubLayout",
      "guards": ["AuthGuard"],
      "sections": [
        {
          "name": "Welcome Header",
          "position": "top",
          "description": "LogiaInitiative logo, greeting with user display name, current date/time, and active shift indicator (if any).",
          "components": ["logo-display", "greeting-text", "shift-status-bar"]
        },
        {
          "name": "Role Menu Grid",
          "position": "center",
          "description": "Large, clear menu cards based on user role. Each card is a gateway to a specific module. Cards shown depend on role and permissions.",
          "components": ["menu-card-large"]
        },
        {
          "name": "Quick Info Bar",
          "position": "bottom",
          "description": "For owner: today quick stats (revenue, orders). For cashier: shift status. For chef: pending order count.",
          "components": ["stat-chip", "shift-status-bar"]
        }
      ]
    }
  ],

  "features": [
    {
      "id": "F-009",
      "title": "Multi-role Authentication / Login",
      "priority": "must_have",
      "acceptance_criteria": [
        "Users can log in with username and password",
        "All users are routed to Main Dashboard Hub after login",
        "Dashboard Hub shows role-appropriate menu cards",
        "Owner can manage all user accounts (create, edit, deactivate, set PIN)",
        "Logged-in users name is displayed in the interface"
      ],
      "business_rules": [
        { "rule": "Each user must have a unique username", "type": "constraint", "source": "F-009.business_rules[0]", "enforcement": "create" },
        { "rule": "After login, ALL users are routed to the Main Dashboard Hub (S-016)", "type": "constraint", "source": "F-009.business_rules[1]", "enforcement": "both" },
        { "rule": "Dashboard Hub shows role-appropriate menu options", "type": "constraint", "source": "F-009.business_rules[2]", "enforcement": "both" },
        { "rule": "Owner can create, edit, and deactivate user accounts", "type": "constraint", "source": "F-009.business_rules[3]", "enforcement": "both" },
        { "rule": "Failed login attempts are logged", "type": "constraint", "source": "F-009.business_rules[4]", "enforcement": "both" },
        { "rule": "Owner can set and reset PIN per user for shift operations", "type": "constraint", "source": "F-009.business_rules[5]", "enforcement": "update" }
      ]
    }
  ],

  "cross_domain_contracts": [
    {
      "flow_id": "UF-007",
      "flow_name": "Full Cashier Journey: Prep to Close Shift",
      "your_steps": [1, 3],
      "context": "Cashier logs in (step 1), then verifies PIN for shift operations (step 3).",
      "triggers_to": [
        { "domain": "shift-management", "action": "PIN verified, cashier can proceed to open shift" }
      ],
      "receives_from": [],
      "timing_notes": []
    },
    {
      "flow_id": "UF-010",
      "flow_name": "Void Paid Transaction",
      "your_steps": [2],
      "context": "Order-management finds paid order (step 1), auth verifies PIN for void (step 2).",
      "triggers_to": [
        { "domain": "payment", "action": "PIN verified, void operation can proceed" }
      ],
      "receives_from": [
        { "domain": "order-management", "data": "Void request requires PIN verification" }
      ],
      "timing_notes": []
    }
  ],

  "state_dependencies": {
    "owns_store": "useAuthStore",
    "writes_to_tables": ["users", "userPermissions"],
    "reads_from_tables": ["shifts"],
    "calls_other_stores": ["useShiftManagementStore"]
  },

  "write_scope": [
    "src/pages/auth/",
    "src/pages/dashboard/",
    "src/components/auth/",
    "src/components/navigation/",
    "src/stores/useAuthStore.ts",
    "server/routes/auth/",
    "server/services/auth/"
  ]
}