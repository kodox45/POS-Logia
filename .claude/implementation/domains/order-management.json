  "features": [
    {
      "id": "F-001",
      "title": "Digital Order Management",
      "priority": "must_have",
      "acceptance_criteria": [
        "Waiter can create a new order by selecting menu items and assigning to a table",
        "If table already has active order, waiter sees option to 'Tambah Pesanan' instead of creating new order",
        "Additional items are appended to existing order and sent to kitchen",
        "Order total updates automatically after adding items",
        "Order appears on Kitchen Display within 2 seconds of submission",
        "Order total is auto-calculated based on menu item prices and quantities",
        "Special notes are visible to the chef on Kitchen Display"
      ],
      "business_rules": [
        { "rule": "Order must have at least one menu item", "type": "constraint", "source": "F-001.business_rules[0]", "enforcement": "create" },
        { "rule": "Order status updates must be real-time across all devices", "type": "constraint", "source": "F-001.business_rules[1]", "enforcement": "both" },
        { "rule": "Each order is linked to a specific table", "type": "constraint", "source": "F-001.business_rules[2]", "enforcement": "create" },
        { "rule": "If a table already has an active (unpaid) order, cashier can ADD items to that existing order instead of creating a new one", "type": "constraint", "source": "F-001.business_rules[3]", "enforcement": "create" },
        { "rule": "Additional items are appended to the same order with Tambahan label", "type": "constraint", "source": "F-001.business_rules[4]", "enforcement": "update" },
        { "rule": "Additional items are sent to kitchen as new items with same order ID", "type": "constraint", "source": "F-001.business_rules[5]", "enforcement": "update" },
        { "rule": "Order total recalculated automatically after adding items", "type": "formula", "source": "F-001.business_rules[6]", "enforcement": "both" },
        { "rule": "Order can be cancelled before payment (status -> cancelled)", "type": "constraint", "source": "F-001.business_rules[7]", "enforcement": "update" }
      ]
    },
    {
      "id": "F-010",
      "title": "Table Management",
      "priority": "should_have",
      "acceptance_criteria": [
        "Visual grid showing all tables with color-coded status",
        "Waiter can tap a table to create or view its active order",
        "Table status updates automatically when order is created/paid",
        "Owner can configure total number of tables"
      ],
      "business_rules": []
    },
    {
      "id": "F-017",
      "title": "Void / Cancel Order & Transaction",
      "priority": "must_have",
      "acceptance_criteria": [
        "Cashier can cancel an unpaid order from order list",
        "Cashier can void a paid transaction (requires PIN)",
        "Void reason selection is mandatory",
        "Voided amounts are reflected in shift expected cash calculation",
        "Close shift summary shows void count and total void amount",
        "Owner can see void history in transaction report"
      ],
      "business_rules": [
        { "rule": "PIN verification required before any void operation", "type": "constraint", "source": "F-017.business_rules[0]", "enforcement": "both" },
        { "rule": "Cancel before payment: order is cancelled, items returned to available, no cash impact", "type": "constraint", "source": "F-017.business_rules[1]", "enforcement": "both" },
        { "rule": "Void after payment (full): full refund tracked, expected cash reduced in shift", "type": "constraint", "source": "F-017.business_rules[2]", "enforcement": "both" },
        { "rule": "Partial void: specific items voided, difference refunded", "type": "constraint", "source": "F-017.business_rules[3]", "enforcement": "both" },
        { "rule": "Void reason is MANDATORY", "type": "constraint", "source": "F-017.business_rules[4]", "enforcement": "both" },
        { "rule": "All voids are logged immutably for audit trail", "type": "constraint", "source": "F-017.business_rules[5]", "enforcement": "both" },
        { "rule": "Voided transactions appear in shift closing summary with separate line", "type": "constraint", "source": "F-017.business_rules[6]", "enforcement": "both" },
        { "rule": "Expected cash formula updated: opening + cash_sales - cash_refunds_from_voids", "type": "formula", "source": "F-017.business_rules[7]", "enforcement": "both" },
        { "rule": "Owner can view all void history with reasons", "type": "constraint", "source": "F-017.business_rules[8]", "enforcement": "both" }
      ]
    }
  ],

