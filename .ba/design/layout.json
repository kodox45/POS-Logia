        "secondary": []
      }
    },    "admin-panel": {
      "name": "Owner / Admin Panel",
      "type": "sidebar",
      "target_roles": ["owner"],
      "cross_role_access": {
        "enabled": true,
        "description": "Non-owner users (cashier, chef) can access certain admin screens (Stok, Menu) from Dashboard Hub based on permissions. When they do, the admin layout renders with a role-quick-access-bar (C-023) at top for quick navigation back to Hub or their primary workspace.",
        "quick_access_bar": "C-023",
        "pin_gate_for_pos": "C-024"
