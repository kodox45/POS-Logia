  "navigation_architecture": {
    "flow": "Login (S-001) → Dashboard Hub (S-016) → Role-specific modules",
    "description": "All users land on a shared Dashboard Hub after login. From there, they choose modules based on their role. Each module may open in a role-specific interface layout (bottom-tabs for waiter, fullscreen for kitchen, sidebar for admin). Users can always return to Dashboard Hub via home/logo button."
  },
  "interfaces": {
    "dashboard-hub": {
      "name": "Main Dashboard Hub",
      "type": "fullscreen-grid",
      "target_roles": ["owner", "waiter-cashier", "chef"],
      "screen_ref": "S-016",
      "header": {
        "height": "64px",
        "content": ["logo-display", "user_profile", "shift_status_bar", "logout_button"]
      },
      "content": {
        "max_width": "800px",
        "padding": "comfortable"
      },
      "navigation": {
        "primary": "role-based menu cards (defined in S-016 role_menus)",
        "home_button": "always visible in all sub-interfaces to return here"
      }
    },
    "waiter-cashier-ui": {
      "name": "Waiter & Cashier Interface",
      "type": "bottom-tabs",
      "target_roles": ["waiter-cashier"],
      "sidebar": null,
      "header": {
        "height": "56px",
        "content": ["shift_status_bar", "user_profile", "notifications"]
      },
      "content": {
        "max_width": "100%",
        "padding": "comfortable"
      },
      "responsive": {
        "mobile_first": true,
        "breakpoints": {
          "mobile": "< 640px",
          "tablet": "640px - 1024px"
        },
        "mobile_navigation": "bottom-tabs"
      },
      "navigation": {
        "primary": [
          { "label": "Pesanan", "icon": "clipboard-list", "screen_ref": "S-002" },
          { "label": "Meja", "icon": "grid", "screen_ref": "S-005" },
          { "label": "Bayar", "icon": "credit-card", "screen_ref": "S-004" }
        ],
        "secondary": []
      }
    },    "kitchen-display": {
      "name": "Kitchen Display System",
      "type": "fullscreen",
      "target_roles": ["chef"],
      "sidebar": null,
      "header": {
        "height": "48px",
        "content": ["user_profile", "order_count_badge"]
      },
      "content": {
        "max_width": "100%",
        "padding": "compact"
